{
  "name": "flowtask",
  "version": "1.0.0",
  "private": true,
  "description": "FlowTask — AI-Powered Task Manager",
  "workspaces": [
    "frontend",
    "backend/node-api",
    "shared"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:api": "npm run dev --workspace=backend/node-api",
    "dev:ml": "cd backend/ml-api && python main.py",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:api\" \"npm run dev:ml\"",
    "build:frontend": "npm run build --workspace=frontend",
    "build:api": "npm run build --workspace=backend/node-api",
    "lint:frontend": "npm run lint --workspace=frontend",
    "lint:api": "npm run lint --workspace=backend/node-api",
    "typecheck": "npm run typecheck --workspace=frontend && npm run typecheck --workspace=backend/node-api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
